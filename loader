function setLoop(name, enabled, interval, callback)
    loops[name] = nil
    if not enabled then
        return
    end

    local token = {}
    loops[name] = token
    task.spawn(function()
        while loops[name] == token do
            local ok, err = pcall(callback)
            if not ok then
                warn("[RoseHub]", name, err)
            end
            task.wait(interval)
        end
    end)
end

