function callRemote(remote, ...)
    if typeof(remote) ~= "Instance" then
        return false
    end

    if remote:IsA("RemoteEvent") then
        return pcall(function(...)
            remote:FireServer(...)
        end, ...)
    elseif remote:IsA("RemoteFunction") then
        return pcall(function(...)
            return remote:InvokeServer(...)
        end, ...)
    end

    return false
end

