function setReplionValue(data, path, value)
    if not data then
        return
    end

    pcall(function()
        data:_set(path, value)
    end)

    if type(path) == "string" then
        local parts = {}
        for part in string.gmatch(path, "[^.]+") do
            table.insert(parts, part)
        end
        if #parts > 0 then
            pcall(function()
                data:_set(parts, value)
            end)
        end
    end
end

