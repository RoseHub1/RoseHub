function playerUsingLoveboard(player)
    local character = player and player.Character
    if not character then
        return false
    end

    for _, item in ipairs(CollectionService:GetTagged("Loveboard")) do
        if item:IsDescendantOf(character) then
            return true
        end
    end

    for _, item in ipairs(character:GetDescendants()) do
        if isLoveboardObject(item) then
            return true
        end
    end

    return false
end

function collectLoveboardObjects(player)
    local found = {}
    local seen = {}
    local function remember(item)
        if item and not seen[item] and isLoveboardObject(item) then
            seen[item] = true
            table.insert(found, item)
        end
    end

    local containers = {}
    if player then
        table.insert(containers, player.Character)
        table.insert(containers, player:FindFirstChildOfClass("Backpack"))
        table.insert(containers, player:FindFirstChild("PlayerGui"))
    else
        table.insert(containers, Workspace)
        table.insert(containers, PlayerGui)
    end

    for _, item in ipairs(CollectionService:GetTagged("Loveboard")) do
        if not player then
            remember(item)
        else
            for _, container in ipairs(containers) do
                if container and item:IsDescendantOf(container) then
                    remember(item)
                end
            end
        end
    end

    for _, container in ipairs(containers) do
        if container then
            for _, item in ipairs(container:GetDescendants()) do
                remember(item)
            end
        end
    end

    return found
end

