function isInventoryCooldownName(name)
    local lower = tostring(name or ""):lower()
    return lower:find("cooldown", 1, true)
        or lower:find("cool down", 1, true)
        or lower:find("debounce", 1, true)
        or lower:find("nextuse", 1, true)
        or lower:find("next use", 1, true)
        or lower:find("equipdelay", 1, true)
        or lower:find("equip delay", 1, true)
        or lower:find("switchdelay", 1, true)
        or lower:find("switch delay", 1, true)
        or lower:find("busy", 1, true)
end

function resetCooldownCarrier(instance)
    if not instance then
        return
    end

    if instance:IsA("BoolValue") and isInventoryCooldownName(instance.Name) then
        instance.Value = false
    elseif (instance:IsA("NumberValue") or instance:IsA("IntValue")) and isInventoryCooldownName(instance.Name) then
        instance.Value = 0
    elseif instance:IsA("StringValue") and isInventoryCooldownName(instance.Name) then
        instance.Value = ""
    end

    for attribute, value in pairs(instance:GetAttributes()) do
        if isInventoryCooldownName(attribute) then
            if type(value) == "boolean" then
                instance:SetAttribute(attribute, false)
            elseif type(value) == "number" then
                instance:SetAttribute(attribute, 0)
            elseif type(value) == "string" then
                instance:SetAttribute(attribute, "")
            end
        end
    end
end

function resetToolCooldown(tool, deep)
    if not tool or not tool:IsA("Tool") then
        return
    end

    pcall(function()
        tool.Enabled = true
    end)
    resetCooldownCarrier(tool)

    if not deep then
        return
    end

    local scanned = 0
    for _, item in ipairs(tool:GetDescendants()) do
        resetCooldownCarrier(item)
        scanned = scanned + 1
        if scanned >= 120 then
            break
        end
    end
end

function isBackpackVisual(instance)
    local current = instance
    while current do
        local name = tostring(current.Name or ""):lower()
        if name:find("rosehub", 1, true) or current:GetAttribute("RoseHubOwned") then
            return false
        end
        if name:find("backpack", 1, true)
            or name:find("hotbar", 1, true)
            or name:find("inventory", 1, true)
        then
            return true
        end
        current = current.Parent
    end
    return false
end

function hideInventorySearchVisuals(root)
