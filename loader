function getPromptText(prompt)
    if not prompt then
        return ""
    end
    return tostring(prompt:GetFullName())
        .. " "
        .. tostring(prompt.ObjectText or "")
        .. " "
        .. tostring(prompt.ActionText or "")
end

function getPromptDineroPrice(prompt)
    local action = tostring(prompt and prompt.ActionText or "")
    if action:lower():find("r$", 1, true) or action:lower():find("robux", 1, true) then
        return math.huge
    end

    local digits = action:gsub("[^%d]", "")
    if digits == "" then
        return nil
    end
    return tonumber(digits)
end

function isFoodPurchasePrompt(prompt, money)
    if not prompt or not prompt.Parent or not prompt.Enabled then
        return false
    end

    local text = getPromptText(prompt)
    if not textHasAny(text, {
        "comprarfires",
        "fires $",
        "fires",
        "fire chips",
        "healing chips",
        "gasstation",
        "gas station",
        "comprarchicken",
        "grilledchicken",
        "chickenbucket",
        "chickennugget",
        "chicken",
        "items purchasers",
        "itemspurchasers",
        "bandage",
        "med kit",
        "medkit",
        "hospital",
        "food",
        "purchase",
        "buy",
    }) then
        return false
    end

    local price = getPromptDineroPrice(prompt)
    if price == math.huge then
        return false
    end
    if price and money and money > 0 and money < price then
        return false
    end
    return true
end

function foodPromptPriority(prompt)
    local text = getPromptText(prompt):lower()
    if text:find("comprarfires", 1, true) or text:find("fires", 1, true) then
        return 140
    end
    if text:find("bandage", 1, true) then
        return 100
    end
    if text:find("chickenbucket", 1, true) or text:find("chicken bucket", 1, true) then
        return 90
    end
    if text:find("chickennugget", 1, true) or text:find("chicken nugget", 1, true) then
        return 85
    end
    if text:find("grilledchicken", 1, true) or text:find("grilled chicken", 1, true) then
        return 80
    end
    if text:find("chicken", 1, true) then
        return 75
    end
    if text:find("med", 1, true) then
        return 30
    end
    return 10
end

function fireFoodPurchasePrompt(prompt, allowFar)
    if not prompt or not prompt.Parent or not prompt.Enabled then
        return false
    end

    local closeEnough = getRootDistance(prompt) <= math.max(40, (tonumber(prompt.MaxActivationDistance) or 0) + 8)
    local trustedFarPrompt = textHasAny(prompt:GetFullName(), {
        "comprarfires",
        "fires",
        "gasstation",
        "comprarchicken",
        "itemspurchasers",
        "hospital",
        "cash",
        "beach",
    })
    if not closeEnough and not allowFar and not trustedFarPrompt then
        return false
    end

    if typeof(fireproximityprompt) ~= "function" then
        local inputOk = false
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(math.max(tonumber(prompt.HoldDuration) or 0, 0) + 0.05)
            prompt:InputHoldEnd()
            inputOk = true
        end)
        if inputOk then
            return true
        end

        local parent = prompt.Parent
        if parent and parent:IsA("BasePart") and closeEnough then
            return touchPart(parent, true)
        end
        return false
    end

    local oldHold = prompt.HoldDuration
    local oldDistance = prompt.MaxActivationDistance
    local oldLineOfSight = prompt.RequiresLineOfSight
    pcall(function()
        prompt.HoldDuration = 0
        prompt.MaxActivationDistance = math.max(oldDistance, 10000)
        prompt.RequiresLineOfSight = false
    end)

    local ok = pcall(function()
        fireproximityprompt(prompt)
    end)

    task.delay(0.2, function()
        if prompt and prompt.Parent then
            pcall(function()
                prompt.HoldDuration = oldHold
                prompt.MaxActivationDistance = oldDistance
                prompt.RequiresLineOfSight = oldLineOfSight
            end)
        end
    end)
    return ok
end

function getFiresPurchasePrompt()
    local part = Workspace:FindFirstChild("comprarFires", true)
    if part then
        local prompt = part:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            return prompt
        end
    end

    for _, prompt in ipairs(getFoodPrompts()) do
        if prompt.Parent and textHasAny(getPromptText(prompt), {
            "comprarfires",
            "fires $",
            "fires",
        }) then
            return prompt
        end
    end
    return nil
end

function getFiresPurchasePart()
    local part = Workspace:FindFirstChild("comprarFires", true)
    if part and part:IsA("BasePart") then
        return part
    end

    local prompt = getFiresPurchasePrompt()
    if prompt and prompt.Parent and prompt.Parent:IsA("BasePart") then
        return prompt.Parent
    end
    return nil
end

function tryBuyFiresAtStation(part, prompt)
    local character, _, root = characterParts()
    if not character or not root or not part or not part:IsA("BasePart") then
        return false
    end

    local returnCFrame = root.CFrame
    local stationCFrame = CFrame.new(part.Position + Vector3.new(0, 3.5, 0), part.Position + root.CFrame.LookVector)
    if not stableTeleportToCFrame(stationCFrame, "Auto Food Heal", true) then
        return false
    end

    task.wait(0.12)
    local bought = false
    prompt = prompt or getFiresPurchasePrompt()
    if prompt then
        for _ = 1, 2 do
            fireFoodPurchasePrompt(prompt, false)
            if waitForFiresTool(0.8) then
                bought = true
                break
            end
            task.wait(0.1)
        end
    end

    if not bought and touchPart(part, false) then
        bought = waitForFiresTool(0.8) ~= nil
    end

    if root.Parent then
        stableTeleportToCFrame(returnCFrame, "Auto Food Heal", true)
    end
    return bought or findFiresTool() ~= nil
end

function tryBuyFires()
    refreshRemotes()
    if findFiresTool() then
        return true
    end

    local money = getDineroAmount()
    if money > 0 and money < 7 then
        return false
    end

    if os.clock() - originals.lastFoodBuyAt < 2 then
        return false
    end
    originals.lastFoodBuyAt = os.clock()

    local prompt = getFiresPurchasePrompt()
    if prompt and fireFoodPurchasePrompt(prompt, true) then
        if waitForFiresTool(0.7) then
            return true
        end
    end

    local part = getFiresPurchasePart()
    if part and part:IsA("BasePart") then
        touchPart(part, true)
        if waitForFiresTool(0.5) then
            return true
        end
        if tryBuyFiresAtStation(part, prompt) then
            return true
        end
    end

    if typeof(Remotes.BuyFood) == "Instance" then
        for _, foodName in ipairs({ "Fires", "Fire Chips", "Healing Chips" }) do
            callRemote(Remotes.BuyFood, foodName)
            if waitForFiresTool(0.25) then
                return true
            end
            callRemote(Remotes.BuyFood, foodName, 1)
            if waitForFiresTool(0.25) then
                return true
            end
            callRemote(Remotes.BuyFood, { ItemName = foodName, Quantity = 1 })
            if waitForFiresTool(0.25) then
                return true
            end
        end
    end

    return false
end

function tryBuyFood()
    refreshRemotes()
    if findFoodTool() then
        return true
    end

    if tryBuyFires() then
        return true
    end

    local money = getDineroAmount()
    if money <= 0 then
        return false
    end

    if os.clock() - originals.lastFoodBuyAt < 3.5 then
        return false
    end
    originals.lastFoodBuyAt = os.clock()

    local prompts = getFoodPrompts()
    table.sort(prompts, function(a, b)
        return foodPromptPriority(a) > foodPromptPriority(b)
    end)

    local fired = 0
    for _, prompt in ipairs(prompts) do
        if isFoodPurchasePrompt(prompt, money) and fireFoodPurchasePrompt(prompt, true) then
            fired = fired + 1
            if waitForFoodTool(0.5) then
                return true
            end
            if fired >= 3 then
                break
            end
        end
    end

    local foodNames = { "Fires", "Fire Chips", "Bandage", "Chicken Bucket", "Chicken Nugget", "Grilled Chicken", "Chicken", "Burger", "Pizza", "Food", "Health Spray" }
    if typeof(Remotes.BuyFood) == "Instance" then
        for _, foodName in ipairs(foodNames) do
            callRemote(Remotes.BuyFood, foodName)
            if waitForFoodTool(0.25) then
                return true
            end
            callRemote(Remotes.BuyFood, foodName, 1)
            if waitForFoodTool(0.25) then
                return true
            end
            callRemote(Remotes.BuyFood, { ItemName = foodName, Quantity = 1 })
            if waitForFoodTool(0.25) then
                return true
            end
        end
    end

    return false
end

function triggerFoodPrompt()
    for _, prompt in ipairs(getFoodPrompts()) do
        if isFoodPurchasePrompt(prompt, getDineroAmount()) and fireFoodPurchasePrompt(prompt, false) then
            return true
        end
    end
    return false
end

function activateFoodTool(tool)
    if not tool or not tool.Parent then
        return false
    end

    local character, humanoid = characterParts()
    if humanoid and character and tool.Parent ~= character then
        pcall(function()
            humanoid:EquipTool(tool)
        end)
        task.wait(0.08)
    end

    local used = false
    local attempts = isFiresTool(tool) and 5 or 3
    for _ = 1, attempts do
        if not tool.Parent then
            break
        end
        resetToolCooldown(tool)
        activateTool(tool)
        used = true
        if isHealthSprayTool(tool) then
            callRemote(Remotes.HealthSpray)
        end
        task.wait(0.16)
    end
    return used
end

function autoFoodHealStep()
    local _, humanoid = characterParts()
    if not humanoid or humanoid.Health <= 0 or humanoid.Health > humanoid.MaxHealth * 0.4 then
        return
    end

    local tool = equipTool(getFiresToolPatterns()) or equipTool(getFoodToolPatterns())
    if tool then
        activateFoodTool(tool)
    else
        local boughtFires = tryBuyFires()
        tool = findFiresTool()
        if not tool and not boughtFires then
            tryBuyFood()
        end
        if not tool then
            triggerFoodPrompt()
            tool = waitForFoodTool(0.8)
        end
        if tool then
            activateFoodTool(tool)
        end
    end

    local healthSpray = findTool({ "health spray", "healthspray" })
    if healthSpray then
        callRemote(Remotes.HealthSpray)
        callRemote(Remotes.HealthSpray, LocalPlayer.Character)
    end
    callRemote(Remotes.ShieldHeal)
end

function tryPickupMoneyObject(item)
    if not item or not item.Parent then
        return false
    end

    refreshRemotes()
    local didPickup = false
    local position = getInstancePosition(item)

    if callRemote(Remotes.PickupMoney, item)
        or callRemote(Remotes.PickupMoney, position)
        or callRemote(Remotes.PickupMoney, item.Name)
    then
        didPickup = true
    end

    if item:IsA("ProximityPrompt") and typeof(fireproximityprompt) == "function" then
