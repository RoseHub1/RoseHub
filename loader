        return
    end

    if cached.parts then
        for part, partState in pairs(cached.parts) do
            restoreHitboxPart(part, partState)
        end
    elseif cached.part then
        restoreHitboxPart(cached.part, cached)
    end
    if cached.box and cached.box.Parent then
        pcall(function()
            cached.box:Destroy()
        end)
    end
    if cached.proxy and cached.proxy.Parent then
        pcall(function()
            cached.proxy:Destroy()
        end)
    end
    originals.hitboxes[player] = nil
end

function getOrCreateRootHitbox(player, size)
    local root = getRoot(player)
    if not root then
        return nil
    end

    originals.hitboxes[player] = originals.hitboxes[player] or {}
    local cached = originals.hitboxes[player]

    if cached.parts then
        for part, partState in pairs(cached.parts) do
            restoreHitboxPart(part, partState)
        end
        cached.parts = nil
    end

    if cached.proxy and cached.proxy.Parent then
        pcall(function()
            cached.proxy:Destroy()
        end)
        cached.proxy = nil
    end

    if cached.part and cached.part ~= root then
        restoreHitboxPart(cached.part, cached)
        cached.part = nil
    end

    if not cached.part then
        cached.part = root
        cached.size = root.Size
        cached.transparency = root.Transparency
        cached.canCollide = root.CanCollide
        cached.canQuery = root.CanQuery
        cached.canTouch = root.CanTouch
        cached.massless = root.Massless
        cached.castShadow = root.CastShadow
    end

    local horizontalSize = clampNumber(tonumber(size) or 5, 2, 30)
    local verticalSize = clampNumber(math.min(horizontalSize, 7), 3, 7)
    root.Size = Vector3.new(horizontalSize, verticalSize, horizontalSize)
    root.Transparency = 1
    root.CanCollide = false
    root.CanQuery = true
    root.CanTouch = true
    root.Massless = true
    root.CastShadow = false

    local box = cached.box
    if not box or not box.Parent then
        box = Instance.new("SelectionBox")
        box.Name = "RoseHubHitboxBox"
        box.Adornee = root
        box.Color3 = Color3.fromRGB(158, 190, 255)
        box.LineThickness = 0.035
        box.SurfaceTransparency = 1
        box.Transparency = 0.15
        box.Parent = root
        cached.box = box
    end
    box.Adornee = root
    return root
end

