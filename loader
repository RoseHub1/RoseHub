function stableTeleportToCFrame(cframe, label, silent)
    if not cframe then
        if not silent then
            notify(label or "Teleport", "Target was not found.", 3)
        end
        return false
    end

    local character, humanoid, root = characterParts()
    if not root then
        if not silent then
            notify(label or "Teleport", "Character was not ready.", 3)
        end
        return false
    end

    pcall(function()
        Workspace:RequestStreamAroundAsync(cframe.Position)
    end)

    local function settle()
        pcall(function()
            if humanoid then
                humanoid.Sit = false
                humanoid.PlatformStand = false
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end)
    end

    local originalAutoRotate = humanoid and humanoid.AutoRotate
    local targetPosition = cframe.Position
    local targetLook = cframe.LookVector
    if targetLook.Magnitude < 0.1 then
        targetLook = root.CFrame.LookVector
    end
    local maxStep = 3.25
    local travelSpeed = 48
    local timeoutAt = os.clock() + clampNumber((targetPosition - root.Position).Magnitude / travelSpeed + 3, 5, 18)

    setTeleportNoclip(true)
    settle()

    pcall(function()
        if humanoid then
            humanoid.AutoRotate = false
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end)

    local ok = true
    while root.Parent and character.Parent and os.clock() < timeoutAt do
        local currentPosition = root.Position
        local offset = targetPosition - currentPosition
        local distance = offset.Magnitude
        if distance <= 4.25 then
            break
        end

        local stepDistance = math.min(maxStep, distance)
        local nextPosition = currentPosition + offset.Unit * stepDistance
        local nextCFrame = CFrame.new(nextPosition, nextPosition + targetLook)
        ok = pcall(function()
            character:PivotTo(nextCFrame)
        end) and ok
        settle()

        local waited = 0
        local waitFor = clampNumber(stepDistance / travelSpeed, 0.04, 0.12)
        while waited < waitFor do
            waited = waited + RunService.Heartbeat:Wait()
            settle()
        end
    end

    settle()
    pcall(function()
        if (targetPosition - root.Position).Magnitude <= 8 then
            character:PivotTo(cframe)
        end
        if humanoid and originalAutoRotate ~= nil then
            humanoid.AutoRotate = originalAutoRotate
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
    end)
    settle()
    task.delay(0.8, function()
        setTeleportNoclip(false)
    end)

    if not silent then
        notify(label or "Teleport", ok and "Teleported." or "Teleport finished with a fallback snap.", 2)
    end
    return true
end

