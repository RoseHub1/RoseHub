function targetIsDowned(player)
    local humanoid = getHumanoid(player)
    if not humanoid then
        return false
    end
    if humanoid.Health <= math.max(2, humanoid.MaxHealth * 0.08) then
        return true
    end

    local character = player.Character
    if not character then
        return false
    end
    for _, item in ipairs(character:GetDescendants()) do
        local name = item.Name:lower()
        if name:find("knocked", 1, true) or name:find("down", 1, true) or name:find("ragdoll", 1, true) then
            if item:IsA("BoolValue") and item.Value then
                return true
            end
        end
    end
    for attribute, value in pairs(character:GetAttributes()) do
        local name = attribute:lower()
        if type(value) == "boolean" and value and (name:find("knocked", 1, true) or name:find("down", 1, true) or name:find("ragdoll", 1, true)) then
            return true
        end
    end
    return false
end

function firePunchAtPlayer(player)
    if player and not canCombatTarget(player, true) then
        return
    end
    refreshRemotes()
    if player then
        callRemote(Remotes.LastHitDetect, player)
        callRemote(Remotes.LastHitDetect, player.Character)
        callRemote(Remotes.LastHitDetect, player.UserId)
    end
    callRemote(Remotes.Punch, 1)
    callRemote(Remotes.Punch, 2)
end

function punchBurst(player, hits)
    hits = hits or 3
    local tool = equipBestCombatTool()
    for _ = 1, hits do
        if player and (not player.Parent or not canCombatTarget(player, true)) then
            break
        end
        if player then
            faceTarget(player)
            lastHitPlayer = player
            lastHitAt = os.clock()
        end
        activateTool(tool)
        firePunchAtPlayer(player)
        task.wait(0.105)
    end
end

function attackPlayer(player, useDrag, bring, moveToTarget)
    if not canCombatTarget(player, true) then
        return false
    end

    local humanoid = getHumanoid(player)
    if not humanoid or humanoid.Health <= 0 then
        return false
    end

    if moveToTarget then
        moveNearTarget(player, bring)
    end

    faceTarget(player)
    punchBurst(player, 3)
    lastHitPlayer = player
    lastHitAt = os.clock()

    if useDrag then
        fireDragOnce(player)
        callRoseHubAction("DamageTarget", {
            targetUserId = player.UserId,
            damage = 25,
            drag = true,
        })
    end

    if targetIsDowned(player) then
        faceTarget(player)
        moveNearTarget(player, bring)
        callRemote(Remotes.Stomp)
    end
    return true
end

function killAuraStep()
    local targets = playersInRange(state.fightDistance, true, true)
    if #targets == 0 then
        if not state.flamethrowerAll and not state.powerfulDrag and not state.targetFarm and not state.stompFarm then
            clearFlamethrowerHitboxes()
        end
        return
    end

    local reach = clampNumber((tonumber(state.fightDistance) or 5) * 2.5 + 8, 14, 120)
    for _, entry in ipairs(targets) do
        applyReachHitboxForPlayer(entry.player, reach)
    end

    local target = targets[1].player
    if not canCombatTarget(target, true) then
        return
    end

    faceTarget(target)
    local tool = equipBestCombatTool()
    activateTool(tool)
    fireAllCombatRemotes(true)
    firePunchAtPlayer(target)
    lastHitPlayer = target
    lastHitAt = os.clock()
end

function autoStompStep()
    local target = lastHitPlayer
    if not target or target == LocalPlayer or not target.Parent or os.clock() - lastHitAt > 12 then
        return
    end
    if not canCombatTarget(target, true) then
        return
    end

    if targetIsDowned(target) then
        faceTarget(target)
        callRoseHubAction("Stomp", { targetUserId = target.UserId })
        callRemote(Remotes.Stomp)
    end
end

function autoDragStep()
    local target = closestPlayer(7, true)
    if target then
        faceTarget(target)
        fireDragOnce(target)
    end
end

function drainTargetHealth(player, forceZero)
    if not canCombatTarget(player, true) then
        return
    end

    local humanoid = getHumanoid(player)
    if not humanoid or humanoid.Health <= 0 then
        return
    end

    local damage = forceZero and math.max(humanoid.MaxHealth * 10, 1000) or math.max(35, humanoid.MaxHealth * 0.45)
    callRoseHubAction("DamageTarget", {
        targetUserId = player.UserId,
        damage = damage,
        drag = true,
    })

    pcall(function()
        humanoid:TakeDamage(damage)
    end)
    pcall(function()
        humanoid.Health = forceZero and 0 or math.max(0, humanoid.Health - damage)
    end)

    local character = player.Character
    if character then
        for attribute, value in pairs(character:GetAttributes()) do
            local name = tostring(attribute):lower()
            if type(value) == "number" and (name:find("health", 1, true) or name:find("hp", 1, true)) then
                pcall(function()
                    character:SetAttribute(attribute, forceZero and 0 or math.max(0, value - damage))
                end)
            end
        end
        for _, item in ipairs(character:GetDescendants()) do
            local name = item.Name:lower()
            if name:find("health", 1, true) and (item:IsA("NumberValue") or item:IsA("IntValue")) then
                pcall(function()
                    item.Value = forceZero and 0 or math.max(0, item.Value - damage)
                end)
            end
            for attribute, value in pairs(item:GetAttributes()) do
                local attr = tostring(attribute):lower()
                if type(value) == "number" and (attr:find("health", 1, true) or attr:find("hp", 1, true)) then
                    pcall(function()
                        item:SetAttribute(attribute, forceZero and 0 or math.max(0, value - damage))
                    end)
                end
            end
        end
    end
end

function pressureDragTarget(player, ticks, forceZero)
    ticks = ticks or 2
    if not canCombatTarget(player, true) then
        return false
    end

    local humanoid = getHumanoid(player)
    if not humanoid or humanoid.Health <= 0 then
        return false
    end

    for _ = 1, ticks do
        if not state.powerfulDrag and not state.targetFarm and not state.stompFarm then
            break
        end

        humanoid = getHumanoid(player)
        if not humanoid or humanoid.Health <= 0 then
            break
        end

        if not canCombatTarget(player, true) then
            break
        end
        if forceZero then
            applyReachHitboxForPlayer(player, REACH_HITBOX_SIZE)
        end
        moveNearTarget(player, false)
        faceTarget(player)
        fireDragOnce(player)
        fireAllCombatRemotes(true)
        punchBurst(player, 1)
        drainTargetHealth(player, forceZero)
        lastHitPlayer = player
        lastHitAt = os.clock()
        task.wait(0.11)
    end

    return true
end

function powerfulDragStep()
    local target = getPlayerByChoice(state.selectedTarget) or closestPlayer(18, true)
    if not canCombatTarget(target, true) then
        return
    end

    pressureDragTarget(target, 6, true)

    if targetIsDowned(target) then
        moveNearTarget(target, false)
        faceTarget(target)
        callRemote(Remotes.Stomp)
    end
end

function targetFarmStep()
    local target = getPlayerByChoice(state.selectedTarget)
    if not target then
        setState("targetFarm", false)
        setLoop("TargetFarm", false)
        notify("Target", "Pick a target before starting.", 3)
        return
    end

    local humanoid = getHumanoid(target)
    if not humanoid or humanoid.Health <= 0 then
        return
    end

    if not canCombatTarget(target, true) then
        return
    end

    pressureDragTarget(target, 6, true)

    humanoid = getHumanoid(target)
    if targetIsDowned(target) or (humanoid and humanoid.Health <= humanoid.MaxHealth * 0.15) then
        moveNearTarget(target, false)
        faceTarget(target)
        callRemote(Remotes.Stomp)
    end
end

function stompFarmStep()
    local candidates = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if canCombatTarget(player, false) and not isStompFarmWhitelisted(player) then
            table.insert(candidates, player)
        end
    end
    if #candidates == 0 then
        return
    end

    if currentFarmIndex > #candidates then
        currentFarmIndex = 1
    end
    local target = candidates[currentFarmIndex]
    if not canCombatTarget(target, true) then
        currentFarmIndex = currentFarmIndex + 1
        return
    end
    pressureDragTarget(target, 6, true)
    if targetIsDowned(target) or not getHumanoid(target) or getHumanoid(target).Health <= 0 then
        moveNearTarget(target, false)
        faceTarget(target)
        callRemote(Remotes.Stomp)
        currentFarmIndex = currentFarmIndex + 1
    end
end

function dodgeFrom(player)
    local _, humanoid, root = characterParts()
    local targetRoot = player and getRoot(player)
    if not humanoid or not root then
        return
    end

    local away = targetRoot and (root.Position - targetRoot.Position)
    if not away or away.Magnitude < 0.1 then
        away = root.CFrame.LookVector
    end
    humanoid:Move(away.Unit, false)
    root.AssemblyLinearVelocity = away.Unit * 155 + Vector3.new(0, 20, 0)
    root.CFrame = root.CFrame + away.Unit * 24 + Vector3.new(0, 2.5, 0)

    if os.clock() - lastDodgeNoticeAt > 0.6 then
        lastDodgeNoticeAt = os.clock()
        notify("Dodged Attack", "Dodged Attack", 1.5)
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "Dodged Attack",
                Text = "Dodged Attack",
                Duration = 1.5,
            })
        end)
    end
end

function playerLooksAggressive(player)
