function disableInstance(instance)
    if not instance or originals.disabled[instance] then
        return
    end

    local cache = { class = instance.ClassName }
    originals.disabled[instance] = cache

    if instance:IsA("BasePart") then
        cache.Transparency = instance.Transparency
        cache.CanCollide = instance.CanCollide
        cache.CanTouch = instance.CanTouch
        cache.CanQuery = instance.CanQuery
        instance.Transparency = 1
        instance.CanCollide = false
        instance.CanTouch = false
        instance.CanQuery = false
    elseif instance:IsA("ProximityPrompt") or instance:IsA("ParticleEmitter") or instance:IsA("Beam") or instance:IsA("Trail") then
        cache.Enabled = instance.Enabled
        instance.Enabled = false
    elseif instance:IsA("LayerCollector") then
        cache.Enabled = instance.Enabled
        instance.Enabled = false
    elseif instance:IsA("GuiObject") then
        cache.Visible = instance.Visible
        instance.Visible = false
    end
end

function disableTree(root)
    if not root then
        return 0
    end

    local count = 0
    disableInstance(root)
    count = count + 1
    for _, item in ipairs(root:GetDescendants()) do
        disableInstance(item)
        count = count + 1
    end
    return count
end

