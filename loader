end

function toolNameContains(tool, patterns)
    if not tool or not tool:IsA("Tool") then
        return false
    end

    local name = tool.Name:lower()
    for _, pattern in ipairs(patterns) do
        if name:find(pattern, 1, true) then
            return true
        end
    end
    return false
end

function isProjectileTool(tool)
    return toolNameContains(tool, {
        "blast bow",
        "bow",
        "cannon",
        "cupid",
        "firework",
        "gravity",
        "harpoon",
        "ice crown",
        "portal",
        "rainbow",
        "slingshot",
        "snowball",
        "spray",
        "trident",
        "water balloon",
        "rpg",
        "rocket",
        "launcher",
        "naughty",
        "nice",
    })
end

function isAmmoTool(tool)
    if not tool or not tool:IsA("Tool") then
        return false
    end

    if toolNameContains(tool, {
        "rpg",
        "snowball",
        "launcher",
        "flamethrower",
        "flame thrower",
        "grenade",
        "gun",
        "pistol",
        "rifle",
        "ammo",
    }) then
        return true
    end

    for attribute in pairs(tool:GetAttributes()) do
        local name = tostring(attribute):lower()
        if name:find("ammo", 1, true)
            or name:find("clip", 1, true)
            or name:find("mag", 1, true)
            or name:find("bullet", 1, true)
            or name:find("fuel", 1, true)
        then
            return true
        end
    end

    for _, item in ipairs(tool:GetDescendants()) do
        local name = item.Name:lower()
        if name:find("ammo", 1, true)
            or name:find("clip", 1, true)
            or name:find("mag", 1, true)
            or name:find("bullet", 1, true)
            or name:find("fuel", 1, true)
        then
            return true
        end
    end

    return false
end

function getEquippedProjectileTool()
    local character = LocalPlayer.Character
    local tool = character and character:FindFirstChildOfClass("Tool")
    if isProjectileTool(tool) then
        return tool
    end
    return nil
end

function setAmmoValuesIn(container)
    if not container then
        return
    end

    for _, item in ipairs(container:GetDescendants()) do
        local name = item.Name:lower()
        local isAmmoName = name:find("ammo", 1, true)
            or name:find("clip", 1, true)
            or name:find("mag", 1, true)
            or name:find("bullet", 1, true)
            or name:find("fuel", 1, true)
            or name:find("rocket", 1, true)
        if isAmmoName and (item:IsA("NumberValue") or item:IsA("IntValue")) then
            item.Value = math.max(tonumber(item.Value) or 0, 999)
        end

        for attribute, value in pairs(item:GetAttributes()) do
            local attr = tostring(attribute):lower()
            if type(value) == "number"
                and (attr:find("ammo", 1, true)
                    or attr:find("clip", 1, true)
                    or attr:find("mag", 1, true)
                    or attr:find("bullet", 1, true)
                    or attr:find("fuel", 1, true)
                    or attr:find("rocket", 1, true))
            then
                item:SetAttribute(attribute, math.max(value, 999))
            end
        end
    end
end

function reloadAmmoTool(tool)
    if not tool or not tool:IsA("Tool") then
        return
    end

    refreshRemotes()
    local name = tool.Name:lower()
    local reloadRemote = nil
    local deactivateRemote = nil

    if name:find("dual", 1, true) or name:find("naughty", 1, true) or name:find("nice", 1, true) or name:find("santa", 1, true) then
        reloadRemote = Remotes.DualRPGReload
    elseif name:find("rpg", 1, true) or name:find("rocket", 1, true) then
        reloadRemote = Remotes.RPGReload
    elseif name:find("grenade", 1, true) then
        reloadRemote = Remotes.GrenadeLauncherReload
    elseif name:find("golden", 1, true) and (name:find("flame", 1, true) or name:find("flamethrower", 1, true)) then
        reloadRemote = Remotes.GoldenFlamethrowerReload
        deactivateRemote = getNetRemote("RE/GoldenFlameThrowerDeactivate")
    elseif name:find("flame", 1, true) or name:find("flamethrower", 1, true) then
        reloadRemote = Remotes.FlamethrowerReload
        deactivateRemote = getNetRemote("RE/flamethrowerDeactivate")
    end

    if reloadRemote then
        callRemote(reloadRemote)
        callRemote(reloadRemote, tool)
        callRemote(reloadRemote, tool.Name)
    end
    if deactivateRemote then
        callRemote(deactivateRemote)
    end
end

function topUpAmmoTool(tool, runReload)
    if not tool or not tool:IsA("Tool") then
        return
    end

    pcall(function()
        tool.Enabled = true
    end)

    local ammoFloor = 999
    for _, attribute in ipairs({
        "Ammo",
        "CurrentAmmo",
        "MaxAmmo",
        "Clip",
        "MaxClip",
        "Magazine",
        "MaxMagazine",
        "Fuel",
        "MaxFuel",
        "Rockets",
        "MaxRockets",
    }) do
        pcall(function()
            local current = tonumber(tool:GetAttribute(attribute))
            if current ~= nil or attribute == "Ammo" or attribute == "MaxAmmo" then
                tool:SetAttribute(attribute, math.max(current or 0, ammoFloor))
            end
        end)
    end

    setAmmoValuesIn(tool)
    if runReload then
        reloadAmmoTool(tool)
    end
end

function clearAmmoToolConnections()
    for tool, bucket in pairs(ammoToolConnections) do
        ammoToolConnections[tool] = nil
        for _, connection in ipairs(bucket) do
            pcall(function()
                connection:Disconnect()
            end)
        end
    end
end

function bindAmmoTool(tool)
    if not isAmmoTool(tool) or ammoToolConnections[tool] then
        return
    end

    local bucket = {}
    ammoToolConnections[tool] = bucket

    local function refreshNow(runReload)
        if not state.infiniteAmmo or not tool.Parent then
            return
        end
        topUpAmmoTool(tool, runReload)
    end

    refreshNow(true)
    table.insert(bucket, tool.Activated:Connect(function()
        refreshNow(true)
        task.delay(0.05, function()
            refreshNow(true)
        end)
        task.delay(0.25, function()
            refreshNow(false)
        end)
    end))
    table.insert(bucket, tool:GetAttributeChangedSignal("Ammo"):Connect(function()
        if state.infiniteAmmo and (tonumber(tool:GetAttribute("Ammo")) or 0) < 999 then
            task.defer(function()
                refreshNow(false)
            end)
        end
    end))
    table.insert(bucket, tool.AncestryChanged:Connect(function()
        if state.infiniteAmmo and tool.Parent then
            task.defer(function()
                refreshNow(false)
            end)
        end
    end))
end

function bindInfiniteAmmoTools(enabled)
    disconnect("InfiniteAmmoBackpack")
    disconnect("InfiniteAmmoCharacter")
    disconnect("InfiniteAmmoCharacterAdded")

    if not enabled then
        clearAmmoToolConnections()
        return
    end

    local function scan(container)
        if not container then
            return
        end
        for _, item in ipairs(container:GetChildren()) do
            bindAmmoTool(item)
        end
    end

    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local character = LocalPlayer.Character
    scan(backpack)
    scan(character)

    if backpack then
        connections.InfiniteAmmoBackpack = backpack.ChildAdded:Connect(function(child)
            task.defer(function()
                if state.infiniteAmmo then
                    bindAmmoTool(child)
                end
            end)
        end)
    end
    if character then
        connections.InfiniteAmmoCharacter = character.ChildAdded:Connect(function(child)
            task.defer(function()
                if state.infiniteAmmo then
                    bindAmmoTool(child)
                end
            end)
        end)
    end
    connections.InfiniteAmmoCharacterAdded = LocalPlayer.CharacterAdded:Connect(function(character)
        task.wait(0.2)
        if state.infiniteAmmo then
            scan(character)
        end
    end)
end

function fireProjectileRemote(remote, origin, direction, aimPoint)
    if typeof(remote) ~= "Instance" then
        return false
    end

    local ok = false
    ok = callRemote(remote, origin, direction, aimPoint) or ok
    ok = callRemote(remote, aimPoint) or ok
    ok = callRemote(remote, origin, direction) or ok
    ok = callRemote(remote, aimPoint, direction, origin) or ok
    return ok
end

function applyInfiniteAmmo()
    refreshRemotes()
    local character = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local containers = { LocalPlayer }
    local toolContainers = {}
    if character then
        table.insert(containers, character)
        table.insert(toolContainers, character)
    end
    if backpack then
        table.insert(containers, backpack)
        table.insert(toolContainers, backpack)
    end

    for _, container in ipairs(containers) do
        setAmmoValuesIn(container)
    end

    local data = getDataReplion()
    if data then
        for _, path in ipairs({
            "Ammo",
            "CurrentAmmo",
            "WeaponAmmo",
            "EquippedAmmo",
            "Stats.Ammo",
            "Stats.CurrentAmmo",
            "NewInventory.Ammo",
            "NewInventory.CurrentAmmo",
            "Weapons.RPG.Ammo",
            "Weapons.Golden RPG.Ammo",
            "Weapons.Snowball Launcher.Ammo",
            "Weapons.Golden Snowball Launcher.Ammo",
            "Weapons.Santa's Naughty or Nice Launcher.Ammo",
            "Weapons.Grenade Launcher.Ammo",
            "Weapons.Flamethrower.Ammo",
            "Weapons.Golden Flamethrower.Ammo",
        }) do
            setReplionValue(data, path, 999)
        end

        local ok, inventory = pcall(function()
            return data:Get("NewInventory.Items")
        end)
        if ok and type(inventory) == "table" then
            for category, items in pairs(inventory) do
                if type(items) == "table" then
                    for id, itemData in pairs(items) do
                        if type(itemData) == "table" then
                            for key, value in pairs(itemData) do
                                local lower = tostring(key):lower()
                                if type(value) == "number"
                                    and (lower:find("ammo", 1, true)
                                        or lower:find("clip", 1, true)
                                        or lower:find("mag", 1, true)
                                        or lower:find("bullet", 1, true)
                                        or lower:find("fuel", 1, true))
                                then
                                    setReplionValue(data, "NewInventory.Items." .. tostring(category) .. "." .. tostring(id) .. "." .. tostring(key), 999)
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    for _, container in ipairs(toolContainers) do
        for _, tool in ipairs(container:GetChildren()) do
            if isAmmoTool(tool) then
                bindAmmoTool(tool)
                topUpAmmoTool(tool, false)
            end
        end
    end

    if os.clock() - lastAmmoReloadAt > 1 then
        lastAmmoReloadAt = os.clock()
        local equipped = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        for _, remote in ipairs({
            Remotes.RPGReload,
            Remotes.DualRPGReload,
            Remotes.GrenadeLauncherReload,
            Remotes.FlamethrowerReload,
            Remotes.GoldenFlamethrowerReload,
        }) do
            callRemote(remote)
            if equipped then
                callRemote(remote, equipped)
                callRemote(remote, equipped.Name)
            end
        end
        if equipped and isAmmoTool(equipped) then
            topUpAmmoTool(equipped, true)
        end
    end
end

function fireSilentAimOnce(force, preferredTool)
    if (not force and not state.silentAim) or os.clock() - lastSilentAimAt < 0.12 then
        return false
    end

    local tool = preferredTool or getEquippedProjectileTool()
    if not tool then
        return false
    end

    local target = closestPlayer(math.huge, true)
    if not canCombatTarget(target, true) then
        return false
    end

    refreshRemotes()
    lastSilentAimAt = os.clock()
    if state.infiniteAmmo then
        applyInfiniteAmmo()
    end

    local camera = Workspace.CurrentCamera
    local _, _, root = characterParts()
    local origin = (root and (root.Position + Vector3.new(0, 3, 0))) or (camera and camera.CFrame.Position)
    local aimPoint = getPredictedAimPoint(target, origin)
    if not aimPoint then
        return false
    end
    origin = origin or aimPoint
    local direction = aimPoint - origin
    if direction.Magnitude < 0.1 then
        direction = Vector3.new(0, 0, -1)
    else
        direction = direction.Unit
    end

    local name = tool.Name:lower()
    topUpAmmoTool(tool, false)
    if name:find("snowball", 1, true) then
        local ok = callRemote(Remotes.SnowballLauncherFire, origin, direction, aimPoint)
        callRemote(Remotes.SnowballLauncherFire, aimPoint, direction, origin)
        return ok
    elseif name:find("naughty", 1, true) or name:find("nice", 1, true) or name:find("dual", 1, true) or name:find("santa", 1, true) then
        return callRemote(Remotes.DualRPGFire, aimPoint)
    elseif name:find("rpg", 1, true) or name:find("rocket", 1, true) then
        return callRemote(Remotes.RPGFire, aimPoint) or callRemote(Remotes.FireRocket, aimPoint)
    elseif name:find("grenade", 1, true) then
        return fireProjectileRemote(Remotes.GrenadeLauncherFire, origin, direction, aimPoint)
    elseif name:find("water", 1, true) and name:find("balloon", 1, true) then
        return fireProjectileRemote(Remotes.WaterBalloonGunFire, origin, direction, aimPoint)
    elseif name:find("cannon", 1, true) then
        return fireProjectileRemote(Remotes.CannonFire, origin, direction, aimPoint)
    elseif name:find("golden", 1, true) and name:find("cupid", 1, true) then
        return fireProjectileRemote(Remotes.GoldenCupidsBowFire, origin, direction, aimPoint)
    elseif name:find("cupid", 1, true) then
        return fireProjectileRemote(Remotes.CupidsBowFire, origin, direction, aimPoint)
    elseif name:find("blast", 1, true) and name:find("bow", 1, true) then
        return fireProjectileRemote(Remotes.BlastBowFire, origin, direction, aimPoint)
    elseif name:find("bow", 1, true) then
        return fireProjectileRemote(Remotes.BowFire, origin, direction, aimPoint)
    elseif name:find("slingshot", 1, true) then
        return fireProjectileRemote(Remotes.SlingshotFire, origin, direction, aimPoint)
    elseif name:find("harpoon", 1, true) then
        return fireProjectileRemote(Remotes.HarpoonFire, origin, direction, aimPoint)
    elseif name:find("trident", 1, true) then
        return fireProjectileRemote(Remotes.TridentFire, origin, direction, aimPoint)
    elseif name:find("firework", 1, true) then
        return fireProjectileRemote(Remotes.FireworkGunFire, origin, direction, aimPoint)
    elseif name:find("gravity", 1, true) then
        return fireProjectileRemote(Remotes.GravityGunFire, origin, direction, aimPoint)
    elseif name:find("portal", 1, true) or name:find("rainbow", 1, true) then
        return fireProjectileRemote(Remotes.RainbowPortalGunFire, origin, direction, aimPoint)
    elseif name:find("ice crown", 1, true) then
        return fireProjectileRemote(Remotes.IceCrownQueenFire, origin, direction, aimPoint)
    elseif name:find("glitter", 1, true) or name:find("blue spray", 1, true) then
        return fireProjectileRemote(Remotes.GlitterBlueSprayFire, origin, direction, aimPoint)
    end

    return false
end

function fireSnowballAtTarget(tool, target)
    if not tool or not target then
        return false
    end

    refreshRemotes()
    topUpAmmoTool(tool, false)

    local camera = Workspace.CurrentCamera
    local _, _, root = characterParts()
    local origin = (root and (root.Position + Vector3.new(0, 3, 0))) or (camera and camera.CFrame.Position)
    local aimPoint = getPredictedAimPoint(target, origin)
    if not origin or not aimPoint then
        return false
    end

    local direction = aimPoint - origin
    if direction.Magnitude < 0.1 then
        direction = Vector3.new(0, 0, -1)
    else
        direction = direction.Unit
    end

    local ok = callRemote(Remotes.SnowballLauncherFire, origin, direction, aimPoint)
    callRemote(Remotes.SnowballLauncherFire, origin, direction, aimPoint + Vector3.new(0, 1.5, 0))
    callRemote(Remotes.SnowballLauncherFire, aimPoint, direction, origin)
    return ok
end

function runSnowballMacro()
    local target = closestPlayer(math.huge, true)
    if not canCombatTarget(target, true) then
        notify("Snowball Macro", "No PVP target found.", 2)
        return
    end

    local fired = 0
    for _, patterns in ipairs({
        { "golden snowball launcher", "golden snowball" },
        { "snowball launcher", "snowball" },
    }) do
        local tool = equipTool(patterns, false)
        if tool then
            topUpAmmoTool(tool, true)
            task.wait(0.06)
            for _ = 1, 3 do
                if fireSnowballAtTarget(tool, target) then
                    fired = fired + 1
                end
                topUpAmmoTool(tool, false)
                activateTool(tool)
                task.wait(0.14)
            end
        end
    end

    local board = equipTool({ "loveboard", "love board" }, false)
    if board then
        activateTool(board)
        task.delay(0.1, function()
            pcall(function()
                board:Deactivate()
            end)
        end)
    end

    notify("Snowball Macro", fired > 0 and "Macro fired." or "Snowball launchers were not found.", 2)
end

