        end)
        keybindCaptureConnection = nil
    end

    local roots = {}
    for root in pairs(roseHubUiRoots) do
        if typeof(root) == "Instance" and root.Parent then
            table.insert(roots, root)
        end
    end

    for _, container in ipairs(getGuiContainers()) do
        for _, child in ipairs(container:GetChildren()) do
            if guiLooksLikeRoseHub(child) or ownedNames[child.Name] or child.Name:sub(1, 7) == "RoseHub" then
                table.insert(roots, child)
            end
        end
        for _, item in ipairs(container:GetDescendants()) do
            local name = item.Name
            local owned = false
            pcall(function()
                owned = item:GetAttribute("RoseHubOwned") == true
            end)
            if owned or ownedNames[name] or name:sub(1, 7) == "RoseHub" then
                table.insert(roots, item)
            elseif item:IsA("TextButton") then
                local text = tostring(item.Text or ""):lower()
                local legacyFloating = text == "use all" or text == "snow" or text == "aim" or text == "aim on"
                local gui = item:FindFirstAncestorWhichIsA("ScreenGui")
                local compact = false
                pcall(function()
                    compact = item.AbsoluteSize.X <= 130 and item.AbsoluteSize.Y <= 80
                end)
                if legacyFloating and gui and (compact or guiLooksLikeRoseHub(gui) or gui.Name:lower():find("rosehub", 1, true)) then
                    table.insert(roots, item)
                end
            end
        end
    end

    for _, instance in ipairs(roots) do
        destroyInstance(instance)
    end
    clearTable(roseHubUiRoots)
end

