function fetchSource(url)
    local ok, result = pcall(function()
        return game:HttpGet(url)
    end)
    if ok and type(result) == "string" and #result > 0 then
        return result
    end

    ok, result = pcall(function()
        pcall(function()
            HttpService.HttpEnabled = true
        end)
        return HttpService:GetAsync(url)
    end)
    if ok and type(result) == "string" and #result > 0 then
        return result
    end

    error("Unable to fetch WindUI from " .. url)
end

local windUiUrls = {
    "https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua",
    "https://github.com/Footagesus/WindUI/releases/download/" .. WINDUI_VERSION .. "/main.lua",
}
function loadWindUI()
    if type(loadChunk) ~= "function" then
        return createFallbackWindUI("loadstring/load is unavailable")
    end

    local lastError = nil
    for _, url in ipairs(windUiUrls) do
        local okSource, source = pcall(fetchSource, url)
        if okSource and type(source) == "string" and #source > 0 then
            local compiled, compileErr = loadChunk(source)
            if type(compiled) == "function" then
                local okUi, ui = xpcall(compiled, function(err)
                    return tostring(err)
                end)
                if okUi and type(ui) == "table" and type(ui.CreateWindow) == "function" then
                    return ui
                end
                lastError = "WindUI failed to initialize: " .. tostring(ui)
            else
                lastError = "WindUI failed to compile: " .. tostring(compileErr)
            end
        else
            lastError = "WindUI source could not be fetched from " .. tostring(url)
        end
    end

    return createFallbackWindUI(lastError or "WindUI source could not be fetched")
end

