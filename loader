function refreshDropdown(dropdown, values)
    if not dropdown then
        return
    end

    pcall(function()
        dropdown:Refresh(values)
    end)
    pcall(function()
        dropdown:SetValues(values)
    end)
    pcall(function()
        dropdown:UpdateValues(values)
    end)
end

