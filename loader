function resolveInputBinding(binding, defaultBinding)
    local text = tostring(binding or "")
    local kind, name = text:match("^(%w+)|(.+)$")
    if kind == "KeyCode" and Enum.KeyCode[name] then
        return Enum.KeyCode[name]
    elseif kind == "UserInputType" and Enum.UserInputType[name] then
        return Enum.UserInputType[name]
    end

    if Enum.KeyCode[text] then
        return Enum.KeyCode[text]
    end
    if Enum.UserInputType[text] then
        return Enum.UserInputType[text]
    end

    if defaultBinding and defaultBinding ~= binding then
        return resolveInputBinding(defaultBinding)
    end
    return Enum.KeyCode.RightShift
end

function resolveKeyCode(name, defaultName)
    local fallbackName = tostring(defaultName or "RightShift")
    local binding = resolveInputBinding(name, fallbackName)
    if tostring(binding):find("Enum.KeyCode.", 1, true) then
        return binding
    end
    return Enum.KeyCode[fallbackName] or Enum.KeyCode.RightShift
end

function formatInputBinding(binding)
    local resolved = resolveInputBinding(binding, binding)
    if typeof(resolved) == "EnumItem" then
        return resolved.Name
    end

    local text = tostring(binding or "")
    local _, name = text:match("^(%w+)|(.+)$")
    return name or text
end

function inputToBinding(input)
    if input.KeyCode and input.KeyCode ~= Enum.KeyCode.Unknown then
        return "KeyCode|" .. input.KeyCode.Name
    end

    if input.UserInputType then
        local inputName = input.UserInputType.Name
        if inputName:find("MouseButton", 1, true) or inputName == "MouseWheel" then
            return "UserInputType|" .. inputName
        end
    end
    return nil
end

