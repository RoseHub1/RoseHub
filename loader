function cloneAdminTool(weaponName, weaponInfo)
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    if not backpack then
        return nil
    end

    local toolName = (weaponInfo and weaponInfo.ToolName) or weaponName
    local toolStorage = ReplicatedStorage:FindFirstChild("exe_storage")
    toolStorage = toolStorage and toolStorage:FindFirstChild("tools")
    local realTool = nil

    if toolStorage then
        for _, child in ipairs(toolStorage:GetChildren()) do
            if child:IsA("Tool") then
                local childToolName = child:GetAttribute("ToolName")
                if childToolName == toolName or child.Name == toolName or child.Name:lower() == tostring(toolName):lower() or child.Name:lower() == tostring(weaponName):lower() then
                    realTool = child
                    break
                end
            end
        end
    end

    local tool
    if realTool then
        tool = realTool:Clone()
    else
        tool = Instance.new("Tool")
        tool.Name = tostring(weaponName)
        tool.TextureId = weaponInfo and weaponInfo.Icon or ""
        tool.RequiresHandle = true
        local handle = Instance.new("Part")
        handle.Name = "Handle"
        handle.Size = Vector3.new(0.5, 0.5, 3)
        handle.Transparency = 1
        handle.CanCollide = false
        handle.Parent = tool
    end

    tool:SetAttribute("AdminTemp", true)
    tool:SetAttribute("OriginalWeapon", tostring(weaponName))
    addAdminWeaponTags(tool, weaponName, weaponInfo)
    tool.Parent = backpack
    protectTool(tool)
    return tool
end

