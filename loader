        didPickup = true
    else
        for _, child in ipairs(item:GetDescendants()) do
            if child:IsA("ProximityPrompt") and typeof(fireproximityprompt) == "function" then
                pcall(function()
                    fireproximityprompt(child)
                end)
                didPickup = true
            elseif child:IsA("ClickDetector") and typeof(fireclickdetector) == "function" then
                pcall(function()
                    fireclickdetector(child)
                end)
                didPickup = true
            end
        end
    end

    local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
    if part and typeof(firetouchinterest) == "function" then
        didPickup = touchPart(part, true) or didPickup
    end

    return didPickup
end

