function applyAntiStomp()
    local character, humanoid, root = characterParts()
    if not character or not humanoid or not root then
        return
    end

    humanoid.Sit = false
    humanoid.PlatformStand = false
    pcall(function()
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end)

    if humanoid.Health > 0 and humanoid.Health <= math.max(12, humanoid.MaxHealth * 0.2) then
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        root.CFrame = root.CFrame + Vector3.new(0, 10, 0)
        if os.clock() - antiStompNoticeAt > 6 then
            antiStompNoticeAt = os.clock()
            antiStompDodging = true
            notify("Anti Stomp Activated!", "Dodging until health is orange.", 4)
            pcall(function()
                StarterGui:SetCore("SendNotification", {
                    Title = "Anti Stomp Activated!",
                    Text = "Dodging until health is orange.",
                    Duration = 4,
                })
            end)
        end
    elseif antiStompDodging and humanoid.Health >= humanoid.MaxHealth * 0.25 then
        antiStompDodging = false
    end

    if antiStompDodging then
        local nearest = closestPlayer(22)
        local targetRoot = nearest and getRoot(nearest)
        local away = targetRoot and (root.Position - targetRoot.Position)
        if away and away.Magnitude > 0 then
            root.CFrame = CFrame.new(root.Position + away.Unit * 9 + Vector3.new(0, 3, 0), root.Position + away.Unit * 12)
        else
            root.CFrame = root.CFrame + Vector3.new(0, 4, 0)
        end
    end
end

