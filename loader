function hourlySpinLooksReady()
    local now = os.time()
    local sawCooldown = false
    local containers = {
        LocalPlayer,
        PlayerGui,
        ReplicatedStorage:FindFirstChild("Shared"),
    }

    for _, container in ipairs(containers) do
        if container then
            for _, item in ipairs(container:GetDescendants()) do
                local name = item.Name:lower()
                if name:find("hourly", 1, true) or name:find("spin", 1, true) then
                    if item:IsA("NumberValue") or item:IsA("IntValue") then
                        if name:find("free", 1, true) or name:find("stock", 1, true) or name:find("available", 1, true) then
                            if item.Value > 0 then
                                return true
                            end
                        elseif name:find("next", 1, true) or name:find("time", 1, true) or name:find("cooldown", 1, true) then
                            sawCooldown = true
                            if item.Value <= now or item.Value <= 0 then
                                return true
                            end
                        end
                    elseif item:IsA("TextLabel") or item:IsA("TextButton") then
                        local text = item.Text:lower()
                        if (text:find("free", 1, true) or text:find("claim", 1, true) or text:find("ready", 1, true))
                            and text:find("spin", 1, true)
                            and not text:find(":", 1, true)
                            and not text:find("come back", 1, true)
                        then
                            return true
                        elseif text:find(":", 1, true) or text:find("come back", 1, true) then
                            sawCooldown = true
                        end
                    end
                end
            end
        end
    end

    if sawCooldown then
        return false
    end
    return now >= (tonumber(state.nextHourlySpinAt) or 0)
end

function autoHourlySpinStep()
