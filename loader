function protectTool(tool)
    if not tool or not tool:IsA("Tool") or protectedTools[tool] then
        return
    end

    snapshotInventoryTool(tool)

    local bucket = {}
    protectedTools[tool] = bucket

    local function resetSoon()
        if not state.removeInventoryCooldown then
            return
        end
        if tool.Parent then
            resetToolCooldown(tool)
        end
    end

    resetToolCooldown(tool)

    table.insert(bucket, tool.Equipped:Connect(function()
        if not state.removeInventoryCooldown then
            return
        end

        local now = os.clock()
        local fastSwitch = now - lastInventoryEquipAt < 0.2
        lastInventoryEquipAt = now
        resetToolCooldown(tool)
        if fastSwitch then
            task.delay(0.05, resetSoon)
        end
        task.delay(0.18, resetSoon)
    end))

    table.insert(bucket, tool:GetPropertyChangedSignal("Enabled"):Connect(function()
        if state.removeInventoryCooldown and tool.Parent and not tool.Enabled then
            task.defer(resetSoon)
        end
    end))

    table.insert(bucket, tool.DescendantAdded:Connect(function(child)
        if state.removeInventoryCooldown then
            task.defer(function()
                resetCooldownCarrier(child)
            end)
        end
    end))

    table.insert(bucket, tool.AncestryChanged:Connect(function(_, parent)
        if state.removeInventoryCooldown then
            if parent then
                task.defer(resetSoon)
            else
                snapshotInventoryTool(tool)
            end
        end
    end))
end

function protectInventoryTools()
