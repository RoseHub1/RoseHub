function findTool(patterns)
    local containers = {
        LocalPlayer.Character,
        LocalPlayer:FindFirstChildOfClass("Backpack"),
    }
    for _, container in ipairs(containers) do
        if container then
            for _, item in ipairs(container:GetChildren()) do
                if item:IsA("Tool") then
                    local name = item.Name:lower()
                    for _, pattern in ipairs(patterns) do
                        if name:find(pattern, 1, true) then
                            return item
                        end
                    end
                end
            end
        end
    end
    return nil
end

function equipTool(patterns, allowFallback)
    local tool = findTool(patterns)
    local character, humanoid = characterParts()
    if tool and humanoid and tool.Parent ~= character then
        if state.removeInventoryCooldown then
            resetToolCooldown(tool)
            local remaining = 0.18 - (os.clock() - lastToolEquipAt)
            if remaining > 0 then
                task.wait(remaining)
            end
        end
        pcall(function()
            humanoid:EquipTool(tool)
        end)
        lastToolEquipAt = os.clock()
    end
    if tool then
        return tool
    end
    return allowFallback and character and character:FindFirstChildOfClass("Tool") or nil
end

function equipBestCombatTool()
    return equipTool({ "fist", "punch", "boxing", "glove", "knuckle", "combat" }, true)
end

function activateTool(tool)
    if tool then
        pcall(function()
            tool.Enabled = true
            tool:Activate()
        end)
