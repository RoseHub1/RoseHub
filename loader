        part.CanCollide = cached.canCollide
        if cached.canQuery ~= nil then
            part.CanQuery = cached.canQuery
        end
        if cached.canTouch ~= nil then
            part.CanTouch = cached.canTouch
        end
        part.Massless = cached.massless
        if cached.castShadow ~= nil then
            part.CastShadow = cached.castShadow
        end
    end)
end

function restoreHitbox(player)
