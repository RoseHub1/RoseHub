function canCombatTarget(player, shouldNotify)
    if not player or player == LocalPlayer or isWhitelisted(player) then
        return false
    end

    local humanoid = getHumanoid(player)
    if not humanoid or humanoid.Health <= 0 then
        return false
    end

    if not isPlayerPvpEnabled(player) then
        if shouldNotify then
            notifyPvpOff(player)
        end
        return false
    end

    return true
end

function closestPlayer(maxDistance, requirePvp)
    local _, _, root = characterParts()
    if not root then
        return nil
    end

    local bestPlayer = nil
    local bestDistance = maxDistance or math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not isWhitelisted(player) and (not requirePvp or canCombatTarget(player, false)) then
            local targetRoot = getRoot(player)
            local humanoid = getHumanoid(player)
            if targetRoot and humanoid and humanoid.Health > 0 then
                local distance = (targetRoot.Position - root.Position).Magnitude
                if distance <= bestDistance then
                    bestDistance = distance
                    bestPlayer = player
                end
            end
        end
    end

    return bestPlayer, bestDistance
end

function playersInRange(maxDistance, requirePvp, notifyPvp)
    local _, _, root = characterParts()
    if not root then
        return {}
    end

    local range = tonumber(maxDistance) or math.huge
    local results = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not isWhitelisted(player) then
            local targetRoot = getRoot(player)
            local humanoid = getHumanoid(player)
            if targetRoot and humanoid and humanoid.Health > 0 then
                local distance = (targetRoot.Position - root.Position).Magnitude
                if distance <= range then
                    if requirePvp and not canCombatTarget(player, false) then
                        if notifyPvp and not isPlayerPvpEnabled(player) then
                            notifyPvpOff(player)
                        end
                    else
                        table.insert(results, {
                            player = player,
                            distance = distance,
                        })
                    end
                end
            end
        end
    end

    table.sort(results, function(left, right)
        return left.distance < right.distance
    end)

    return results
end

function getAimPoint(player)
    local character = player and player.Character
    if not character then
        return nil
    end

    local head = character:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        return head.Position
    end

    local root = getRoot(player)
    return root and (root.Position + Vector3.new(0, 1.6, 0)) or nil
end

function getPredictedAimPoint(player, origin)
    local character = player and player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local point = getAimPoint(player)
    if not point or not root or not origin then
        return point
    end

    local velocity = root.AssemblyLinearVelocity
    if velocity.Magnitude > 55 then
        velocity = velocity.Unit * 55
    end

    local distance = (point - origin).Magnitude
    local travelTime = clampNumber(distance / 90, 0, 1.1) * 0.2
    return point + velocity * travelTime
end

function targetVisibleFromCamera(player)
    local camera = Workspace.CurrentCamera
    local character = player and player.Character
    local point = getAimPoint(player)
    if not camera or not character or not point then
        return false
    end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = { LocalPlayer.Character, character }
    params.IgnoreWater = true

    local result = Workspace:Raycast(camera.CFrame.Position, point - camera.CFrame.Position, params)
    return result == nil
end

function playerClosestToLook()
    local camera = Workspace.CurrentCamera
    if not camera then
        return nil
    end

    local viewport = camera.ViewportSize
    local center = Vector2.new(viewport.X * 0.5, viewport.Y * 0.5)
    local bestPlayer = nil
    local bestScore = -math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if canCombatTarget(player, false) then
            local point = getAimPoint(player)
            if point then
                local screenPoint, visible = camera:WorldToViewportPoint(point)
                local offset = Vector2.new(screenPoint.X, screenPoint.Y) - center
                local direction = point - camera.CFrame.Position
                if visible and direction.Magnitude > 0.1 and targetVisibleFromCamera(player) then
                    local dot = direction.Unit:Dot(camera.CFrame.LookVector)
                    if dot > 0.55 then
                        local screenPenalty = offset.Magnitude / math.max(viewport.X, viewport.Y)
                        local score = dot - screenPenalty
                        if score > bestScore then
                            bestScore = score
                            bestPlayer = player
                        end
                    end
                end
            end
        end
    end

    return bestPlayer
end

