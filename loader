function rejoinServer()
    local ok, err = pcall(function()
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
    end)
    if not ok then
        notify("Rejoin Server", tostring(err), 4)
    end
end

function serverHop()
    local ok, body = pcall(function()
        return game:HttpGet(("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(game.PlaceId))
    end)
    if not ok then
        pcall(function()
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end)
        return
    end

    local decoded = {}
    pcall(function()
        decoded = HttpService:JSONDecode(body)
    end)
    for _, server in ipairs(decoded.data or {}) do
        if server.id ~= game.JobId and server.playing < server.maxPlayers then
            local didTeleport = pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
            end)
            if not didTeleport then
                notify("Server Hop", "Teleport request failed.", 4)
            end
            return
        end
    end
    local didTeleport = pcall(function()
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end)
    if not didTeleport then
        notify("Server Hop", "No open server was found.", 4)
    end
end

