function fireAllCombatRemotes(silent)
    refreshRemotes()
    local args = { 1 }
    local fired = 0

    local explicit = {
        { remote = Remotes.Sledgehammer, args = args },
        { remote = Remotes.Spray, args = {} },
        { remote = Remotes.PinkStopSignal, args = args },
        { remote = Remotes.StickActivated, args = args },
        { remote = Remotes.Punch, args = args },
        { remote = Remotes.Punch, args = {} },
        { remote = Remotes.RequestPunch, args = args },
    }

    for _, item in ipairs(explicit) do
        if callRemote(item.remote, unpackArgs(item.args)) then
            fired = fired + 1
        end
    end

    for _, remote in ipairs(Remotes.WeaponHits or {}) do
        if callRemote(remote, 1) then
            fired = fired + 1
        end
    end

    local net = getNetFolder()
    if net then
        for _, remote in ipairs(net:GetChildren()) do
            if remote:IsA("RemoteEvent") and remote ~= Remotes.Sledgehammer and remote ~= Remotes.Spray and remote ~= Remotes.PinkStopSignal and remote ~= Remotes.StickActivated then
                local name = remote.Name:lower()
                if name:find("hit", 1, true) or name:find("activate", 1, true) then
                    if callRemote(remote, unpackArgs(args)) then
                        fired = fired + 1
                    end
                end
            end
        end
    end

    if not silent then
        notify("Use All", ("Fired %d combat remotes."):format(fired), 2)
    end
    return fired
end

