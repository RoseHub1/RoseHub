function breakLoveboards()
    callRoseHubAction("BreakLoveboards")
    callRemote(Remotes.RemoveLoveboard)
    callRemote(Remotes.SetBoard, false)

    local loveboardObjects = {}
    local function remember(instance)
        if instance and not loveboardObjects[instance] then
            loveboardObjects[instance] = true
        end
    end

    for _, item in ipairs(CollectionService:GetTagged("Loveboard")) do
        remember(item)
    end

    local dismounts = 0
    for _, player in ipairs(Players:GetPlayers()) do
        local character = player.Character
        if character then
            for _, item in ipairs(character:GetDescendants()) do
                if isLoveboardObject(item) then
                    remember(item)
                end
            end
        end

        for _, board in ipairs(collectLoveboardObjects(player)) do
            remember(board)
            if callRemote(Remotes.SetBoard, false, board) then
                dismounts = dismounts + 1
            end
            callRemote(Remotes.GetBoard, false, board)
            callRemote(Remotes.RemoveLoveboard, board)
        end

        if player ~= LocalPlayer and playerUsingLoveboard(player) then
            callRemote(Remotes.RemoveLoveboard, player)
            callRemote(Remotes.RemoveLoveboard, player.UserId)
            callRemote(Remotes.RemoveLoveboard, player.Name)
            callRemote(Remotes.RemoveLoveboard, character)
            callRemote(Remotes.SetBoard, false, player)
            callRemote(Remotes.SetBoard, false, player.UserId)
            callRemote(Remotes.GetBoard, false, player)
        end
    end

    local count = 0
    local containers = {
        Workspace,
        PlayerGui,
        LocalPlayer:FindFirstChildOfClass("Backpack"),
    }
    for _, player in ipairs(Players:GetPlayers()) do
        table.insert(containers, player.Character)
        table.insert(containers, player:FindFirstChild("PlayerGui"))
    end

    for _, container in ipairs(containers) do
        if container then
            for _, item in ipairs(container:GetDescendants()) do
                if isLoveboardObject(item) then
                    remember(item)
                end
            end
        end
    end

    for item in pairs(loveboardObjects) do
        callRemote(Remotes.GetBoard, false, item)
        callRemote(Remotes.SetBoard, false, item)
        callRemote(Remotes.RemoveLoveboard, item)
        count = count + disableTree(item)
        if item:IsA("Tool") then
            item.Enabled = false
            pcall(function()
                item:Deactivate()
            end)
        end
    end

    local flung = flingLoveboardUsers()
    if not state.breakLoveboards or flung > 0 then
        notify("Break People's Loveboards", ("Dismounted %d boards. Disabled %d local objects. Flung %d riders."):format(dismounts, count, flung), 3)
    end
end

