        markNewScreenGuis(windowGuiSnapshot)
        markWindowGuiInstances(Window)
    end

    local ok, tab = pcall(function()
        return Window:Tab(config)
    end)
    if ok
        and type(tab) == "table"
        and type(tab.Button) == "function"
        and type(tab.Toggle) == "function"
        and type(tab.Slider) == "function"
        and type(tab.Dropdown) == "function"
    then
        return tab
    end

    windowGuiSnapshot = snapshotScreenGuis()
    WindUI = createFallbackWindUI("Window tab creation failed: " .. tostring(tab))
    Window = createRoseWindow()
    markNewScreenGuis(windowGuiSnapshot)
    markWindowGuiInstances(Window)
    return Window:Tab(config)
end

