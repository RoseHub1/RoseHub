    end

    for _, item in ipairs(character:GetDescendants()) do
        local name = item.Name:lower()
        if name:find("punch", 1, true) or name:find("attack", 1, true) or name:find("swing", 1, true) then
            if item:IsA("BoolValue") and item.Value then
                return true
            end
        end
    end
    for attribute, value in pairs(character:GetAttributes()) do
        local name = attribute:lower()
        if type(value) == "boolean" and value and (name:find("punch", 1, true) or name:find("attack", 1, true) or name:find("swing", 1, true)) then
            return true
        end
    end
    return false
end

function autoDodgeStep()
    local _, humanoid = characterParts()
    if not humanoid then
        return
    end

    if lastHealth and humanoid.Health < lastHealth then
        local attacker = closestPlayer(28)
        if attacker then
